<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<!--
  Suppressions for rules that require touching business logic or
  are stylistic divergences from the existing codebase (4-space indent,
  existing Javadoc style, existing string formatting).
  These suppressions keep the build green without modifying production logic.
-->
<suppressions>

  <!-- 4-space indentation; Google Style requires 2. Fixing requires touching every class body. -->
  <suppress checks="Indentation" files=".*\.java"/>

  <!-- Javadoc formatting rules that fire on existing comments. -->
  <suppress checks="MissingJavadocMethod" files=".*\.java"/>
  <suppress checks="MissingJavadocType" files=".*\.java"/>
  <suppress checks="SummaryJavadoc" files=".*\.java"/>
  <suppress checks="JavadocTagContinuationIndentation" files=".*\.java"/>
  <suppress checks="JavadocVariable" files=".*\.java"/>
  <suppress checks="JavadocMethod" files=".*\.java"/>
  <suppress checks="JavadocParagraph" files=".*\.java"/>
  <suppress checks="AtclauseOrder" files=".*\.java"/>
  <suppress checks="NonEmptyAtclauseDescription" files=".*\.java"/>
  <suppress checks="InvalidJavadocPosition" files=".*\.java"/>
  <suppress checks="RequireEmptyLineBeforeBlockTagGroup" files=".*\.java"/>
  <suppress checks="SingleLineJavadoc" files=".*\.java"/>

  <!-- GoldenE2ETest: abbreviation E2E in class name. -->
  <suppress checks="AbbreviationAsWordInName" files=".*Test\.java"/>

</suppressions>
